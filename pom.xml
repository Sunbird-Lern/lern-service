<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>org.sunbird</groupId>
    <artifactId>lern-service</artifactId>
    <version>1.0-SNAPSHOT</version>
    <packaging>pom</packaging>

    <name>Lern Service</name>
    <description>Unified learning service supporting userorg, lms, and notification modules</description>

    <properties>
        <!-- Compiler Settings -->
        <maven.compiler.release>11</maven.compiler.release>
        <maven.compiler.source>11</maven.compiler.source>
        <maven.compiler.target>11</maven.compiler.target>

        <!-- Project Encoding -->
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>

        <!-- Common Versions -->
        <play2.plugin.version>1.0.0-rc5</play2.plugin.version>
        <play2.version>3.0.5</play2.version>
        <scala.major.version>2.13</scala.major.version>
        <scala.version>2.13.12</scala.version>
        <pekko.version>1.0.3</pekko.version>
        <jackson.version>2.14.3</jackson.version>
        <netty.version>4.1.112.Final</netty.version>
        <junit.version>4.13.1</junit.version>
        <powermock.version>2.0.9</powermock.version>
        <slf4j.version>2.0.13</slf4j.version>
        <logback.version>1.4.14</logback.version>
        <kafka.version>3.7.1</kafka.version>

        <!-- Dependency Versions -->
        <surefire.plugin.version>3.0.0</surefire.plugin.version>
        <guava.version>32.1.2-jre</guava.version>
        <jacoco-maven-plugin.version>0.8.8</jacoco-maven-plugin.version>
        <asm.version>9.2</asm.version>
        <guice.version>6.0.0</guice.version>
        <apache.httpcomponents.version>4.5.14</apache.httpcomponents.version>
        <apache.httpcore.version>4.4.16</apache.httpcore.version>
        <logstash-logback-encoder.version>7.3</logstash-logback-encoder.version>
    </properties>

    <!-- 
        Core module is the foundation for all other modules.
        It contains shared utilities, base classes which are required by all modules.
    -->
    <modules>
        <module>core</module>
    </modules>

    <profiles>
        <!-- Build userorg service only -->
        <profile>
            <id>userorg</id>
            <modules>
                <module>modules/userorg</module>
            </modules>
        </profile>

        <!-- Build lms service only (future) -->
        <profile>
            <id>lms</id>
            <modules>
                <module>modules/lms</module>
            </modules>
        </profile>

        <!-- Build notification service only (future) -->
        <profile>
            <id>notification</id>
            <modules>
                <module>modules/notification</module>
            </modules>
        </profile>

        <!-- Build all services together (Lern Service mode) -->
        <profile>
            <id>lern</id>
            <modules>
                <module>modules/userorg</module>
                <module>modules/lms</module>
                <module>modules/notification</module>
                <module>modules/lern/service</module>
                <module>lern-jacoco-report</module>
            </modules>
        </profile>
    </profiles>
    
    <dependencyManagement>
        <dependencies>
            <!-- Standardize Logging versions -->
            <dependency>
                <groupId>org.slf4j</groupId>
                <artifactId>slf4j-api</artifactId>
                <version>${slf4j.version}</version>
            </dependency>
            <dependency>
                <groupId>ch.qos.logback</groupId>
                <artifactId>logback-classic</artifactId>
                <version>${logback.version}</version>
            </dependency>
            <dependency>
                <groupId>ch.qos.logback</groupId>
                <artifactId>logback-core</artifactId>
                <version>${logback.version}</version>
            </dependency>
            <dependency>
                <groupId>org.slf4j</groupId>
                <artifactId>jcl-over-slf4j</artifactId>
                <version>${slf4j.version}</version>
            </dependency>
            <dependency>
                <groupId>org.slf4j</groupId>
                <artifactId>jul-to-slf4j</artifactId>
                <version>${slf4j.version}</version>
            </dependency>
            <dependency>
                <groupId>org.slf4j</groupId>
                <artifactId>log4j-over-slf4j</artifactId>
                <version>${slf4j.version}</version>
            </dependency>

            <!-- Standardize Jackson -->
            <dependency>
                <groupId>com.fasterxml.jackson.core</groupId>
                <artifactId>jackson-core</artifactId>
                <version>${jackson.version}</version>
            </dependency>
            <dependency>
                <groupId>com.fasterxml.jackson.core</groupId>
                <artifactId>jackson-databind</artifactId>
                <version>${jackson.version}</version>
            </dependency>
            <dependency>
                <groupId>com.fasterxml.jackson.core</groupId>
                <artifactId>jackson-annotations</artifactId>
                <version>${jackson.version}</version>
            </dependency>

            <!-- Standardize Pekko -->
            <dependency>
                <groupId>org.apache.pekko</groupId>
                <artifactId>pekko-actor_${scala.major.version}</artifactId>
                <version>${pekko.version}</version>
            </dependency>
            <dependency>
                <groupId>org.apache.pekko</groupId>
                <artifactId>pekko-slf4j_${scala.major.version}</artifactId>
                <version>${pekko.version}</version>
            </dependency>

            <!-- Standardize Guava -->
            <dependency>
                <groupId>com.google.guava</groupId>
                <artifactId>guava</artifactId>
                <version>${guava.version}</version>
            </dependency>

            <!-- Standardize Guice -->
            <dependency>
               <groupId>com.google.inject</groupId>
               <artifactId>guice</artifactId>
               <version>${guice.version}</version>
            </dependency>

            <!-- Standardize Netty -->
            <dependency>
                <groupId>io.netty</groupId>
                <artifactId>netty-common</artifactId>
                <version>${netty.version}</version>
            </dependency>
            <dependency>
                <groupId>io.netty</groupId>
                <artifactId>netty-buffer</artifactId>
                <version>${netty.version}</version>
            </dependency>
            <dependency>
                <groupId>io.netty</groupId>
                <artifactId>netty-transport</artifactId>
                <version>${netty.version}</version>
            </dependency>
            <dependency>
                <groupId>io.netty</groupId>
                <artifactId>netty-handler</artifactId>
                <version>${netty.version}</version>
            </dependency>
            <dependency>
                <groupId>io.netty</groupId>
                <artifactId>netty-codec</artifactId>
                <version>${netty.version}</version>
            </dependency>
            <dependency>
                <groupId>io.netty</groupId>
                <artifactId>netty-resolver</artifactId>
                <version>${netty.version}</version>
            </dependency>
            <dependency>
                <groupId>io.netty</groupId>
                <artifactId>netty-resolver-dns</artifactId>
                <version>${netty.version}</version>
            </dependency>
            <dependency>
                <groupId>io.netty</groupId>
                <artifactId>netty-codec-dns</artifactId>
                <version>${netty.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <dependencies>
        <!-- Test Dependencies -->
        <dependency>
            <groupId>junit</groupId>
            <artifactId>junit</artifactId>
            <version>4.13.1</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- 
                Surefire Plugin for running unit tests.
                Configured to support Java 11 modules and parallel execution.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.0.0</version>
                <configuration>
                    <useSystemClassLoader>false</useSystemClassLoader>
                    <argLine>
                        @{argLine} --illegal-access=permit
                    </argLine>
                    <properties>
                        <property>
                            <name>parallel</name>
                            <value>methods</value>
                        </property>
                        <property>
                            <name>dataproviderthreadcount</name>
                            <value>30</value>
                        </property>
                    </properties>
                </configuration>
            </plugin>

            <!-- 
                Maven Enforcer Plugin to enforce project build requirements.
                Ensures minimum Java 11 and Maven 3.6.0 versions.
                Prevents duplicate dependency versions.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-enforcer-plugin</artifactId>
                <version>3.5.0</version>
                <executions>
                    <execution>
                        <id>enforce-build-environment</id>
                        <goals>
                            <goal>enforce</goal>
                        </goals>
                        <configuration>
                            <rules>
                                <requireMavenVersion>
                                    <version>[3.6.0,)</version>
                                </requireMavenVersion>
                                <requireJavaVersion>
                                    <version>[11,)</version>
                                </requireJavaVersion>
                                <banDuplicatePomDependencyVersions/>
                            </rules>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- 
                JaCoCo Plugin for Code Coverage reporting.
                Excludes generated routes and model classes from coverage metrics.
            -->
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>0.8.8</version>
                <configuration>
                    <destFile>${project.build.directory}/jacoco.exec</destFile>
                    <dataFile>${project.build.directory}/jacoco.exec</dataFile>
                    <excludes>
                        <exclude>**/Reverse*/**</exclude>
                        <exclude>**/routes.*</exclude>
                        <exclude>**/routes$javascript.**</exclude>
                        <exclude>org/sunbird/models/**/*</exclude>
                    </excludes>
                </configuration>
                <executions>
                    <execution>
                        <goals>
                            <goal>prepare-agent</goal>
                            <goal>report</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
